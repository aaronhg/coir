{
  "name": "coir",
  "version": "0.1.0",
  "description": "Coir — load a Cocos Creator 3.8 project in the browser and explore asset usage + dependency topology",
  "type": "module",
  "bin": {
    "coir": "src/cli.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "webpack serve --mode development --config webpack.config.cjs",
    "start": "webpack serve --mode development --config webpack.config.cjs",
    "build": "webpack --mode production --config webpack.config.cjs",
    "scan": "node test/node-run.js",
    "cli": "node src/cli.js",
    "test": "node --test test/*.test.js"
  },
  "devDependencies": {
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  },
  "license": "MIT"
}
